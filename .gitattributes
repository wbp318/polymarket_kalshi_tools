# Line endings — normalize on commit, checkout as OS-appropriate
* text=auto

# Source code and text formats always LF (prevents CRLF warnings on Windows)
*.py         text eol=lf
*.pyw        text eol=lf
*.yaml       text eol=lf
*.yml        text eol=lf
*.json       text eol=lf
*.toml       text eol=lf
*.ini        text eol=lf
*.cfg        text eol=lf
*.md         text eol=lf
*.txt        text eol=lf
*.sh         text eol=lf
*.ps1        text eol=lf crlf=input
*.bat        text eol=crlf
*.cmd        text eol=crlf
.gitignore   text eol=lf
.gitattributes text eol=lf
requirements.txt text eol=lf
Dockerfile   text eol=lf

# Binary formats — no line-ending conversion
*.png  binary
*.jpg  binary
*.jpeg binary
*.gif  binary
*.ico  binary
*.pdf  binary
*.zip  binary
*.tar  binary
*.gz   binary
*.db   binary


